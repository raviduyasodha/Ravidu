{
    "version": 2,
    "outputDirectory": "dist",
    "builds": [
        {
            "src": "dist/index.php",
            "use": "vercel-php@0.7.0"
        },
        {
            "src": "dist/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "dist/build/$1"
        },
        {
            "src": "/(css|js|images|favicon.ico|robots.txt)(.*)",
            "dest": "/dist/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "dist/index.php"
        }
    ]
}